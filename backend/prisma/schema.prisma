generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  firebaseUid   String?   @unique
  username      String?   @unique
  email         String?   @unique
  phone         String?   @unique
  password      String?   // Added for Admin/Custom auth
  showPhoneTo   String    @default("everyone")
  searchByPhone Boolean   @default(true)
  displayName   String?
  avatar        String?
  largeAvatar   String?
  bio           String?
  role          String?
  dob           DateTime?
  showBirthday  Boolean   @default(true)
  isPrivate     Boolean   @default(false)
  settings      Json      @default("{}") // Store theme, notification prefs, privacy toggles
  invitationSettings String @default("everyone") // everyone, mutual, no_one
  appLockPin    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLogin     DateTime?
  
  // Relations
  followers        UserFollows[] @relation("following")
  following        UserFollows[] @relation("followers")
  sentFollowReqs   FollowRequest[] @relation("sentFollowRequests")
  receivedFollowReqs FollowRequest[] @relation("receivedFollowRequests")
  
  posts       Post[]
  stories     Story[]
  likes       Like[]
  commentLikes CommentLike[]
  comments    Comment[]
  
  chatParticipants ChatParticipant[]
  folders          ChatFolder[]
  messages         Message[]
  messageReactions MessageReaction[]
  savedPosts       SavedPost[]
  storyViews       StoryView[]
  notifications    Notification[] @relation("userNotifications")
  actions          Notification[] @relation("actorActions")
  
  activities       Activity[]     @relation("userActivity")
  actorActivities  Activity[]     @relation("actorActivity")
  
  blockedByMe      BlockedUser[]  @relation("blocker")
  blockedMe        BlockedUser[]  @relation("blocked")
  reportsByMe      Report[]       @relation("reporter")
  reportsAgainstMe Report[]       @relation("reported")
  sessions         Session[]
  callerCalls      CallLog[]      @relation("callerCalls")
  calleeCalls      CallLog[]      @relation("calleeCalls")

  aiConversations  AIConversation[]
  aiMemories       AIMemory[]
  aiTasks          AITask[]
  aiActions        AIAction[]

  @@index([firebaseUid])
  @@index([username])
}

// ... existing models ...

model AIConversation {
  id        String   @id @default(uuid())
  userId    String
  agentName String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AIMemory {
  id         String   @id @default(uuid())
  userId     String
  memoryType String
  content    String
  embedding  Float[]
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AITask {
  id          String    @id @default(uuid())
  userId      String
  task        String
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AIAction {
  id         String   @id @default(uuid())
  userId     String
  actionType String
  payload    Json
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}


model UserFollows {
  followerId    String
  followingId   String

  follower      User      @relation("followers", fields: [followerId], references: [id])
  following     User      @relation("following", fields: [followingId], references: [id])

  @@id([followerId, followingId])
}

model FollowRequest {
  id          String   @id @default(uuid())
  senderId    String
  receiverId  String
  status      String   @default("pending") // pending, accepted, rejected
  createdAt   DateTime @default(now())

  sender      User     @relation("sentFollowRequests", fields: [senderId], references: [id])
  receiver    User     @relation("receivedFollowRequests", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String   // The person receiving the notification
  actorId     String   // The person who triggered the notification
  type        String   // follow, follow_request, message, like, etc.
  targetId    String?  // Optional: ID of the post, chat, or story involved
  text        String?  // Optional: notification message content
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation("userNotifications", fields: [userId], references: [id])
  actor       User     @relation("actorActions", fields: [actorId], references: [id])
}

enum GroupRole {
  MEMBER
  ADMIN
  OWNER
}

model Chat {
  id                String            @id @default(uuid())
  name              String?
  avatar            String?
  description       String?
  isGroup           Boolean           @default(false)
  isSecret          Boolean           @default(false)
  selfDestructTimer Int?
  inviteToken       String?           @unique
  settings          Json              @default("{}") // e.g {"canMessage": "everyone", "restricted": false}
  deletedFor        String[]          @default([])
  updatedAt         DateTime          @updatedAt
  createdAt         DateTime          @default(now())

  participants      ChatParticipant[]
  messages          Message[]
}

model ChatParticipant {
  id        String    @id @default(uuid())
  chatId    String
  userId    String
  role      GroupRole @default(MEMBER)
  status    String    @default("JOINED") // JOINED, INVITED, DECLINED
  isArchived Boolean  @default(false)
  isPinned  Boolean   @default(false)
  joinedAt  DateTime  @default(now())

  chat      Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
}

model ChatFolder {
  id        String   @id @default(uuid())
  userId    String
  name      String
  chatIds   String[] @default([])
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Message {
  id          String   @id @default(uuid())
  chatId      String
  senderId    String
  text        String?
  imageUrl    String?
  videoUrl    String?
  fileUrl     String?
  audioUrl    String?
  document    Json?
  location    Json?
  contact     Json?
  payment     Json?
  schedule    Json?
  wallet      Json?
  gifUrl      String?  // High-definition GIF support
  sharedPostId String? // ID of the shared post
  sharedStoryId String? // ID of the shared story
  isForwarded Boolean  @default(false)
  isHD        Boolean  @default(false) // Whether to server original or compressed
  fileName    String?
  fileSize    Int?     // In bytes
  mimeType    String?
  replyToId   String?
  status      String   @default("sent") // sent, delivered, seen
  isEdited    Boolean  @default(false)
  isRead      Boolean  @default(false)
  isPinned    Boolean  @default(false)
  reactions   MessageReaction[]
  deletedFor  Json?    @default("[]")
  createdAt   DateTime @default(now())
  
  chat      Chat     @relation(fields: [chatId], references: [id])
  sender    User     @relation(fields: [senderId], references: [id])

  @@index([chatId, createdAt])
  @@index([senderId, createdAt])
}

model Post {
  id        String   @id @default(uuid())
  authorId  String
  content   String?
  mediaUrl  String?
  mediaType String?  // 'image', 'video'
  location  String?
  isCommentsDisabled Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     Like[]
  comments  Comment[]
  savedBy   SavedPost[]

  @@index([authorId, createdAt(sort: Desc)])
}

model Story {
  id        String   @id @default(uuid())
  userId    String
  mediaUrl  String
  mediaType String   // 'image', 'video'
  content   String?
  reactions Json     @default("{}") // e.g {"❤️": ["user1"]}
  hiddenFrom String[] @default([]) // Array of User IDs
  createdAt DateTime @default(now())
  expiresAt DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  views     StoryView[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([expiresAt])
}

model StoryView {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  viewedAt  DateTime @default(now())

  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@index([storyId])
}

model SavedPost {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  savedAt   DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  content   String
  parentId  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  likes     CommentLike[]

  @@index([postId, createdAt])
}

model CommentLike {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model Activity {
  id        String   @id @default(uuid())
  userId    String   // Recipient
  actorId   String   // Performer
  type      String   // 'LIKE', 'COMMENT', 'FOLLOW', 'MENTION'
  postId    String?
  storyId   String?
  text      String?  // Context
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation("userActivity", fields: [userId], references: [id], onDelete: Cascade)
  actor     User     @relation("actorActivity", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model BlockedUser {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker   User @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
}

model Report {
  id         String   @id @default(uuid())
  reporterId String
  reportedId String
  reason     String?
  status     String   @default("pending") // pending, resolved, dismissed
  adminNotes String?
  createdAt  DateTime @default(now())

  reporter   User @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported   User @relation("reported", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([reportedId])
  @@index([status])
}

model MutedChat {
  id        String    @id @default(uuid())
  userId    String
  chatId    String
  mutedUntil DateTime?
  createdAt DateTime  @default(now())

  @@unique([userId, chatId])
  @@index([userId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  device    String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CallLog {
  id        String   @id @default(uuid())
  callerId  String
  calleeId  String
  type      String   // 'VOICE' | 'VIDEO'
  status    String   @default("initiated") // initiated, ringing, active, ended, missed, rejected
  startedAt DateTime @default(now())
  endedAt   DateTime?
  duration  Int?     // seconds
  roomId    String?  @unique
  agoraToken String?

  caller    User @relation("callerCalls", fields: [callerId], references: [id], onDelete: Cascade)
  callee    User @relation("calleeCalls", fields: [calleeId], references: [id], onDelete: Cascade)

  @@index([callerId, startedAt(sort: Desc)])
  @@index([calleeId, startedAt(sort: Desc)])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// ─────────────────────────────────────────────────────────────────
// Channels — public/private broadcast rooms with active membership
// ─────────────────────────────────────────────────────────────────
enum ChannelType {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

model Channel {
  id              String      @id @default(uuid())
  name            String
  handle          String      @unique // @channelname
  description     String?
  avatar          String?
  banner          String?
  category        String?     // Tech, Creative, Lifestyle, etc.
  type            ChannelType @default(PUBLIC)
  ownerId         String
  isVerified      Boolean     @default(false)
  isDiscoverable  Boolean     @default(true) // AI discovery opt-in
  memberCount     Int         @default(0)
  settings        Json        @default("{}") // slowMode, postPermission, etc.
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  members         ChannelMember[]
  posts           ChannelPost[]

  @@index([category])
  @@index([type, isDiscoverable])
  @@index([ownerId])
}

model ChannelMember {
  id        String    @id @default(uuid())
  channelId String
  userId    String
  role      GroupRole @default(MEMBER) // reuse MEMBER/ADMIN/OWNER
  joinedAt  DateTime  @default(now())

  channel   Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([channelId])
}

model ChannelPost {
  id          String   @id @default(uuid())
  channelId   String
  authorId    String
  content     String?
  mediaUrl    String?
  mediaType   String?  // image, video
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())

  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt(sort: Desc)])
}

