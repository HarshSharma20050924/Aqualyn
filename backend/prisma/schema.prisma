generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  firebaseUid   String    @unique
  username      String?   @unique
  email         String?   @unique
  phone         String?   @unique
  showPhoneTo   String    @default("everyone")
  searchByPhone Boolean   @default(true)
  displayName   String?
  avatar        String?
  largeAvatar   String?
  bio           String?
  role          String?
  dob           DateTime?
  showBirthday  Boolean   @default(true)
  isPrivate     Boolean   @default(false)
  settings      Json      @default("{}") // Store theme, notification prefs, privacy toggles
  invitationSettings String @default("everyone") // everyone, mutual, no_one
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLogin     DateTime?
  
  // Relations
  followers        UserFollows[] @relation("following")
  following        UserFollows[] @relation("followers")
  sentFollowReqs   FollowRequest[] @relation("sentFollowRequests")
  receivedFollowReqs FollowRequest[] @relation("receivedFollowRequests")
  
  posts       Post[]
  stories     Story[]
  likes       Like[]
  comments    Comment[]
  
  chatParticipants ChatParticipant[]
  messages         Message[]
  notifications    Notification[] @relation("userNotifications")
  actions          Notification[] @relation("actorActions")
  
  activities       Activity[]     @relation("userActivity")
  actorActivities  Activity[]     @relation("actorActivity")

  @@index([firebaseUid])
  @@index([username])
}

model UserFollows {
  followerId    String
  followingId   String

  follower      User      @relation("followers", fields: [followerId], references: [id])
  following     User      @relation("following", fields: [followingId], references: [id])

  @@id([followerId, followingId])
}

model FollowRequest {
  id          String   @id @default(uuid())
  senderId    String
  receiverId  String
  status      String   @default("pending") // pending, accepted, rejected
  createdAt   DateTime @default(now())

  sender      User     @relation("sentFollowRequests", fields: [senderId], references: [id])
  receiver    User     @relation("receivedFollowRequests", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String   // The person receiving the notification
  actorId     String   // The person who triggered the notification
  type        String   // follow, follow_request, message, like, etc.
  targetId    String?  // Optional: ID of the post, chat, or story involved
  text        String?  // Optional: notification message content
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation("userNotifications", fields: [userId], references: [id])
  actor       User     @relation("actorActions", fields: [actorId], references: [id])
}

enum GroupRole {
  MEMBER
  ADMIN
  OWNER
}

model Chat {
  id                String            @id @default(uuid())
  name              String?
  avatar            String?
  description       String?
  isGroup           Boolean           @default(false)
  isSecret          Boolean           @default(false)
  selfDestructTimer Int?
  inviteToken       String?           @unique
  settings          Json              @default("{}") // e.g {"canMessage": "everyone", "restricted": false}
  deletedFor        String[]          @default([])
  updatedAt         DateTime          @updatedAt
  createdAt         DateTime          @default(now())

  participants      ChatParticipant[]
  messages          Message[]
}

model ChatParticipant {
  id        String    @id @default(uuid())
  chatId    String
  userId    String
  role      GroupRole @default(MEMBER)
  joinedAt  DateTime  @default(now())

  chat      Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
}

model Message {
  id          String   @id @default(uuid())
  chatId      String
  senderId    String
  text        String?
  imageUrl    String?
  videoUrl    String?
  fileUrl     String?
  audioUrl    String?
  document    Json?
  location    Json?
  contact     Json?
  payment     Json?
  schedule    Json?
  wallet      Json?
  gifUrl      String?  // High-definition GIF support
  sharedPostId String? // ID of the shared post
  sharedStoryId String? // ID of the shared story
  isForwarded Boolean  @default(false)
  isHD        Boolean  @default(false) // Whether to server original or compressed
  fileName    String?
  fileSize    Int?     // In bytes
  mimeType    String?
  replyToId   String?
  status      String   @default("sent") // sent, delivered, seen
  isEdited    Boolean  @default(false)
  isRead      Boolean  @default(false)
  reactions   Json?    @default("{}")
  deletedFor  Json?    @default("[]")
  createdAt   DateTime @default(now())
  
  chat      Chat     @relation(fields: [chatId], references: [id])
  sender    User     @relation(fields: [senderId], references: [id])

  @@index([chatId, createdAt])
  @@index([senderId, createdAt])
}

model Post {
  id        String   @id @default(uuid())
  authorId  String
  content   String?
  mediaUrl  String?
  mediaType String?  // 'image', 'video'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     Like[]
  comments  Comment[]

  @@index([authorId, createdAt(sort: Desc)])
}

model Story {
  id        String   @id @default(uuid())
  userId    String
  mediaUrl  String
  mediaType String   // 'image', 'video'
  content   String?
  reactions Json     @default("{}") // e.g {"❤️": ["user1"]}
  hiddenFrom String[] @default([]) // Array of User IDs
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  content   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model Activity {
  id        String   @id @default(uuid())
  userId    String   // Recipient
  actorId   String   // Performer
  type      String   // 'LIKE', 'COMMENT', 'FOLLOW', 'MENTION'
  postId    String?
  storyId   String?
  text      String?  // Context
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation("userActivity", fields: [userId], references: [id], onDelete: Cascade)
  actor     User     @relation("actorActivity", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}
